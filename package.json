    "homebridge": ">=1.6.0"
  },
  "peerDependencies": {
    "homebridge": ">=1.6.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "homebridge": "^1.8.0",
    "typescript": "^5.0.0"
  }
}
