{
  "name": "homebridge-grizzl-e",
  "version": "0.1.4",
  "description": "Homebridge plugin for Grizzl-E Connect EV chargers — expose chargers as HomeKit outlets to enable/disable charging",
  "license": "MIT",
  "author": "Justin Prest",
  "main": "dist/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/justinjsp/homebridge-grizzl-e.git"
  },
  "bugs": {
    "url": "https://github.com/justinjsp/homebridge-grizzl-e/issues"
  },
  "homepage": "https://github.com/justinjsp/homebridge-grizzl-e#readme",
  "files": [
    "dist",
    "config.schema.json"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "prepublishOnly": "npm run build"
  },
  "homebridge": {
